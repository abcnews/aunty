{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "noEmit": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*"]
}
