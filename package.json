{
  "name": "@abcnews/aunty",
  "version": "17.0.0-next.5",
  "type": "module",
  "description": "ABC News Digital developer toolkit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abcnews/aunty.git"
  },
  "license": "MIT",
  "contributors": [
    "Colin Gourlay <gourlay.colin@abc.net.au>",
    "Simon Elvery <elvery.simon@abc.net.au>",
    "Joshua Byrd <byrd.joshua@abc.net.au>",
    "Ash Kyd <kyd.ashley@abc.net.au>"
  ],
  "scripts": {
    "build": "esbuild src/bin/aunty.ts src/bin/commander.ts src/lib/vite.ts --bundle --platform=node --format=esm --packages=external --outdir=dist && tsc",
    "watch": "esbuild src/bin/aunty.ts src/bin/commander.ts src/lib/vite.ts --bundle --platform=node --format=esm --packages=external --outdir=dist --watch",
    "prepublishOnly": "npm run build",
    "dev": "npm run watch",
    "test": "node --experimental-test-module-mocks --import tsx --test test/*.test.ts",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "release": "np"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/bin/aunty.js",
  "exports": {
    ".": "./dist/bin/aunty.js",
    "./vite": "./dist/lib/vite.js"
  },
  "bin": {
    "aunty": "dist/bin/aunty.js",
    "nt": "dist/bin/aunty.js"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/async": "^3.2.25",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.0.10",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "install": "^0.13.0",
    "np": "^12.0.0",
    "npm": "^11.11.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "async": "^3.2.6",
    "basic-ftp": "^5.2.0",
    "commander": "^14.0.3",
    "lodash-es": "^4.17.23",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5",
    "slugify": "^1.6.8",
    "tsx": "^4.21.0",
    "zx": "^8.8.5"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true
  }
}
